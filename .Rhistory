## -----------------------------------------------------------------------------
## Download INKAR data
## -----------------------------------------------------------------------------
### Functions ###
inkar_multi <- function(var_vec, num_vec) {
if (length(var_vec) != length(num_vec)) {
stop("Die Vektoren 'var_vec' und 'num_vec' müssen gleich lang sein.")
}
data_list <- list()
meta <- data.frame()
for (i in seq_along(var_vec)) {
var <- var_vec[i]
num <- num_vec[i]
df <-  get_data(variable=num, geography = "GEM") %>%
mutate(Time = as.numeric(Zeit)) %>%
filter(Time==max(Time)) %>%
rename(ID=Schlüssel) %>%
rename(var := Wert) %>%
select(c("ID", "Raumbezug", var, "Time"))
data_list[[var]] <- df
meta_append <- get_metadata(num)
meta_append$var <- var
meta <- rbind(meta, meta_append)
}
return(list(
data = data_list,
meta = meta
))
}
inkar_multi <- function(var_vec, num_vec) {
if (length(var_vec) != length(num_vec)) {
stop("Vector 'var_vec' und 'num_vec' doesn't have the same length.")
}
data_list <- list()
meta <- data.frame()
for (i in seq_along(var_vec)) {
var <- var_vec[i]
num <- num_vec[i]
df <-  get_data(variable=num, geography = "GEM") %>%
mutate(Time = as.numeric(Zeit)) %>%
filter(Time==max(Time)) %>%
rename(ID=Schlüssel) %>%
rename(var = Wert) %>%
select(c("ID", "Raumbezug", var, "Time"))
data_list[[var]] <- df
meta_append <- get_metadata(num)
meta_append$var <- var
meta <- rbind(meta, meta_append)
}
return(list(
data = data_list,
meta = meta
))
}
