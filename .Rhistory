inkar_fun <- function(x, y) {
get_data(variable=y, geography = "GEM") %>%
mutate(Time = as.numeric(Zeit)) %>%
filter(Time==max(Time)) %>%
rename(ID=Schlüssel) %>%
rename({{ x }} := Wert) %>%
select(c("ID", "Raumbezug", {{x}}, "Time"))
}
