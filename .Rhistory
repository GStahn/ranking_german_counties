common_n <- names(obs_gem_list[obs_gem_list == 10775])
lst_same <- gem_list$data[common_n]
merged_gem <- lst_same %>%
reduce(left_join, by="ID") %>%
select(-ends_with(".y")) %>%
select(-ends_with(".x")) %>%
select(-Time)
merged_gem <- lst_same %>%
reduce(left_join, by="ID")
View(merged_gem)
merged_gem <- lst_same %>%
reduce(left_join, by="ID") %>%
select(-ends_with(".y")) %>%
select(-ends_with(".x"))
View(merged_gem)
rm(meta_kre_vote, meta_kre)
uncommon_n <- names(obs_gem_list[obs_gem_list != 10775])
lst_notsame <- gem_list$data[uncommon_n]
View(lst_notsame)
bigger_n <- names(obs_gem_list[obs_gem_list > 10775])
lst_bigger <- gem_list$data[uncommon_n]
View(lst_bigger)
lst_bigger <- gem_list$data[bigger_n]
View(lst_bigger)
lst_bigger <- lst_bigger %>%
reduce(filter(ID %in% housing_id))
lst_bigger <- lst_bigger %>%
reduce(filter("ID" %in% housing_id))
lst_bigger <- lst_bigger %>%
keep(ID %in% housing_id)
lst_bigger <- lst_bigger %>%
map(~ keep(ID, ID %in% housing_id))
